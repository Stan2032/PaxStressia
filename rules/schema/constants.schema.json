{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "constants.schema.json",
  "title": "PaxStressia constants file (rules/constants.json)",
  "description": "Every tunable in the simulation, named exactly as referenced in DESIGN.md §18.5. All values PROPOSED until the v0.5 history-calibration pass; every balance change is a one-line diff here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "turn_scale", "start_date", "horizon_turns", "starting", "treasury_income",
    "mandate_base", "honeymoon_mult", "honeymoon_turns", "lameduck_mult", "lameduck_turns",
    "election_period_turns", "election_k", "continuity_reversion",
    "k_recruit", "junta_recruit_amp", "sponsor_flow", "k_pool", "k_alliance", "k_partner", "k_attrit",
    "spread_threshold", "k_spread",
    "entrench_strength_min", "entrench_pressure_max", "k_entrench", "k_entrench_decay",
    "vis_floor", "vis_contest", "vis_quiet", "vis_smooth", "pressure_ref",
    "link_threshold", "affinity_floor",
    "collapse_ratio", "collapse_dist_decay", "w_junta", "w_failed", "w_emirate",
    "junta_gov_hit", "junta_grievance_hit", "junta_patron_gain",
    "fog_sigma_max", "fog_calm_bias", "fog_entrench_mult",
    "order_junta_weight", "order_bloc_weight", "integrity_floor", "drift_per_tier",
    "cost_per_casualty", "cost_spend_norm", "domestic_hit_per_casualty",
    "edge_interdiction_cap", "event_chance", "patron_drift_junta",
    "press_freedom", "leak_base", "leak_age_factor", "leak_clock_turns", "leak_multiplier",
    "bloc_consolidate_rate", "bloc_max_stage", "bloc_pressure", "bloc_expansion_grievance",
    "exposure_decay", "exposure_patron_relief", "exposure_bloc_relief",
    "patron_competitiveness_intl", "patron_competitiveness_exposure",
    "sanctions_exposure_min", "sanctions_intl", "sanctions_patron", "sanctions_bloc_slow",
    "sanctions_exposure_cost", "negotiate_min", "negotiate_max", "negotiate_strength_drain",
    "negotiate_domestic_cost", "negotiate_international_gain",
    "pax_abroad_min", "integrity_clean_min"
  ],
  "properties": {
    "turn_scale": { "type": "string", "enum": ["month", "quarter"] },
    "start_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "horizon_turns": { "type": "integer", "minimum": 1 },
    "starting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domestic", "international", "treasury"],
      "properties": {
        "domestic": { "type": "number", "minimum": 0, "maximum": 100 },
        "international": { "type": "number", "minimum": 0, "maximum": 100 },
        "treasury": { "type": "number", "minimum": 0 }
      }
    },
    "treasury_income": { "type": "number", "minimum": 0 },
    "mandate_base": { "type": "number", "minimum": 0 },
    "honeymoon_mult": { "type": "number", "minimum": 0 },
    "honeymoon_turns": { "type": "integer", "minimum": 0 },
    "lameduck_mult": { "type": "number", "minimum": 0 },
    "lameduck_turns": { "type": "integer", "minimum": 0 },
    "election_period_turns": { "type": "integer", "minimum": 1 },
    "election_k": { "type": "number", "exclusiveMinimum": 0 },
    "continuity_reversion": { "type": "number", "minimum": 0, "maximum": 1 },
    "k_recruit": { "type": "number", "minimum": 0 },
    "junta_recruit_amp": { "type": "number", "minimum": 0 },
    "sponsor_flow": { "type": "number", "minimum": 0 },
    "k_pool": { "type": "number", "minimum": 0 },
    "k_alliance": { "type": "number", "minimum": 0 },
    "k_partner": { "type": "number", "minimum": 0 },
    "k_attrit": { "type": "number", "minimum": 0 },
    "spread_threshold": { "type": "number", "minimum": 0, "maximum": 100, "description": "Strength above which a faction spreads over open edges (v0.4, §18.5)." },
    "k_spread": { "type": "number", "minimum": 0, "description": "Spread flow coefficient (v0.4, §18.5)." },
    "entrench_strength_min": { "type": "number", "minimum": 0, "maximum": 100 },
    "entrench_pressure_max": { "type": "number", "minimum": 0 },
    "k_entrench": { "type": "number", "minimum": 0 },
    "k_entrench_decay": { "type": "number", "minimum": 0 },
    "vis_floor": { "type": "number", "minimum": 0, "maximum": 100 },
    "vis_contest": { "type": "number", "minimum": 0 },
    "vis_quiet": { "type": "number", "minimum": 0 },
    "vis_smooth": { "type": "number", "minimum": 0, "maximum": 1 },
    "pressure_ref": { "type": "number", "exclusiveMinimum": 0 },
    "link_threshold": { "type": "number", "minimum": 0 },
    "affinity_floor": { "type": "number", "minimum": -1, "maximum": 1 },
    "collapse_ratio": { "type": "number", "exclusiveMinimum": 0 },
    "collapse_dist_decay": { "type": "number", "minimum": 0, "description": "Distance discount on collapse threat per hop from the capital (v0.5, §18.5)." },
    "w_junta": { "type": "number", "minimum": 0 },
    "w_failed": { "type": "number", "minimum": 0 },
    "w_emirate": { "type": "number", "minimum": 0 },
    "junta_gov_hit": { "type": "number", "minimum": 0 },
    "junta_grievance_hit": { "type": "number", "minimum": 0 },
    "junta_patron_gain": { "type": "number", "minimum": 0 },
    "fog_sigma_max": { "type": "number", "minimum": 0 },
    "fog_calm_bias": { "type": "number", "minimum": 0, "maximum": 1 },
    "fog_entrench_mult": { "type": "number", "minimum": 1 },
    "order_junta_weight": { "type": "number", "minimum": 0 },
    "order_bloc_weight": { "type": "number", "minimum": 0 },
    "integrity_floor": { "type": "number", "minimum": 0, "maximum": 1 },
    "drift_per_tier": { "type": "number", "minimum": 0 },
    "cost_per_casualty": { "type": "number", "minimum": 0 },
    "cost_spend_norm": { "type": "number", "minimum": 0 },
    "domestic_hit_per_casualty": { "type": "number", "minimum": 0 },
    "edge_interdiction_cap": { "type": "number", "minimum": 0, "maximum": 1 },
    "event_chance": { "type": "number", "minimum": 0, "maximum": 1 },
    "patron_drift_junta": { "type": "number", "minimum": 0 },
    "press_freedom": { "type": "number", "minimum": 0, "maximum": 1, "description": "Strength of the free press (v0.6): higher makes suppression more likely to leak — democracies can't hide things (§6 Transparency Dial)." },
    "leak_base": { "type": "number", "minimum": 0, "maximum": 1, "description": "Base per-turn leak chance for a suppressed scandal." },
    "leak_age_factor": { "type": "number", "minimum": 0, "description": "Added leak chance per turn the suppression ages." },
    "leak_clock_turns": { "type": "integer", "minimum": 1, "description": "Turns a suppressed scandal can survive before it is buried for good." },
    "leak_multiplier": { "type": "number", "minimum": 1, "description": "A leak costs this multiple of the honest disclosure — the gamble's downside." },
    "bloc_consolidate_rate": { "type": "number", "minimum": 0, "description": "Stage gained per turn by an authoritarian bloc (§5.4)." },
    "bloc_max_stage": { "type": "number", "minimum": 1, "description": "Cap on bloc consolidation stage." },
    "bloc_pressure": { "type": "number", "minimum": 0, "description": "International-legitimacy drain per bloc stage per turn (pooled propaganda)." },
    "bloc_expansion_grievance": { "type": "number", "minimum": 0, "description": "Grievance a consolidated bloc exports to adjacent civilian regions per turn." },
    "exposure_decay": { "type": "number", "minimum": 0, "description": "Exposure lost per turn without upkeep — the truth fades (§20)." },
    "exposure_patron_relief": { "type": "number", "minimum": 0, "maximum": 1, "description": "How much full exposure raises the price of the rival patron's offer." },
    "exposure_bloc_relief": { "type": "number", "minimum": 0, "maximum": 1, "description": "How much full exposure blunts a bloc's propaganda pressure." },
    "patron_competitiveness_intl": { "type": "number", "minimum": 0, "maximum": 1, "description": "Weight of your International standing in resisting patron capture." },
    "patron_competitiveness_exposure": { "type": "number", "minimum": 0, "maximum": 1, "description": "Weight of regime Exposure in resisting patron capture." },
    "sanctions_exposure_min": { "type": "number", "minimum": 0, "maximum": 100, "description": "Exposure needed before a targeted designation bites (§20.4)." },
    "sanctions_intl": { "type": "number", "minimum": 0, "description": "International gained by a well-evidenced designation." },
    "sanctions_patron": { "type": "number", "minimum": 0, "description": "Patron influence stripped by a designation." },
    "sanctions_bloc_slow": { "type": "number", "minimum": 0, "description": "Bloc stage rolled back by a designation." },
    "sanctions_exposure_cost": { "type": "number", "minimum": 0, "description": "Exposure spent to mount a designation." },
    "negotiate_min": { "type": "number", "minimum": 0, "maximum": 100, "description": "Lower strength bound for a faction to be negotiable (stalemate band, §7)." },
    "negotiate_max": { "type": "number", "minimum": 0, "maximum": 100, "description": "Upper strength bound for negotiability." },
    "negotiate_strength_drain": { "type": "number", "minimum": 0, "description": "Strength a successful settlement removes." },
    "negotiate_domestic_cost": { "type": "number", "minimum": 0, "description": "Domestic cost of negotiating ('soft on terror')." },
    "negotiate_international_gain": { "type": "number", "minimum": 0, "description": "International gained by a negotiated settlement." },
    "pax_abroad_min": { "type": "number", "minimum": 0, "description": "Abroad score (Stabilization × OrderMultiplier) needed to count as holding the line, for the endings matrix (§11)." },
    "integrity_clean_min": { "type": "number", "minimum": 0, "maximum": 1, "description": "IntegrityMultiplier at/above which you count as having kept clean hands (endings matrix)." },
    "notes": { "type": "object", "additionalProperties": { "type": "string" } }
  }
}
